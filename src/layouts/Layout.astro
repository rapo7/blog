---
import PostHog from "../components/common/PostHog.astro";
import SiteNav from "../components/SiteNav";

import "../styles/index.css";
import { ClientRouter, fade } from "astro:transitions";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="A personal Website that is a collection of my thought and my info" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={import.meta.env.BASE_URL + "/favicon.svg"} />
    <link rel="sitemap" href={import.meta.env.BASE_URL + "/sitemap-index.xml"} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const modeKey = "themeMode";
        const familyKey = "themeFamily";
        const familySessionKey = "themeFamilySession";
        const stored = localStorage.getItem(modeKey);
        const legacy = localStorage.getItem("theme");
        const mode =
          stored === "light" || stored === "dark" || stored === "system"
            ? stored
            : legacy === "light" || legacy === "dark"
              ? legacy
              : "system";
        const families = ["neo", "anthropic", "openai", "wise", "jake"];
        const storedFamily = localStorage.getItem(familyKey);
        const sessionFamily = sessionStorage.getItem(familySessionKey);
        const shouldRandomize =
          !families.includes(storedFamily) &&
          (!families.includes(sessionFamily) ||
            performance.getEntriesByType("navigation")[0]?.type === "reload");
        const randomIndex = shouldRandomize && typeof crypto !== "undefined" && "getRandomValues" in crypto
          ? (() => {
              const values = new Uint32Array(1);
              crypto.getRandomValues(values);
              return values[0] % families.length;
            })()
          : Math.floor(Math.random() * families.length);
        const family =
          families.includes(storedFamily)
            ? storedFamily
            : shouldRandomize
              ? families[randomIndex] || "neo"
              : sessionFamily;
        sessionStorage.setItem(familySessionKey, family);
        const getSystemTheme = () =>
          window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        const applyTheme = (targetDocument, nextMode = mode, nextFamily = family, resolvedTheme) => {
          targetDocument.documentElement.dataset.theme =
            resolvedTheme || (nextMode === "system" ? getSystemTheme() : nextMode);
          targetDocument.documentElement.dataset.themeMode = nextMode;
          targetDocument.documentElement.dataset.themeFamily = nextFamily;
        };

        applyTheme(document);

        document.addEventListener("astro:before-swap", (event) => {
          const currentRoot = document.documentElement;
          const nextMode = currentRoot.dataset.themeMode || mode;
          const nextFamily = currentRoot.dataset.themeFamily || family;
          const nextTheme = currentRoot.dataset.theme || (nextMode === "system" ? getSystemTheme() : nextMode);
          sessionStorage.setItem(familySessionKey, nextFamily);
          applyTheme(event.newDocument, nextMode, nextFamily, nextTheme);
        });

        document.addEventListener("astro:after-swap", () => {
          const currentRoot = document.documentElement;
          const nextMode = currentRoot.dataset.themeMode || mode;
          const nextFamily = currentRoot.dataset.themeFamily || family;
          const nextTheme = currentRoot.dataset.theme || (nextMode === "system" ? getSystemTheme() : nextMode);
          applyTheme(
            document,
            nextMode,
            nextFamily,
            nextTheme,
          );
        });
      })();
    </script>
    <style>
      html {
        scroll-behavior: smooth;
        scroll-padding-top: 6rem;
      }

      body {
        font-family: var(--font-body);
      }
    </style>
    <PostHog />
    <ClientRouter />
  </head>
  <body
    class="h-full flex flex-col overflow-x-hidden bg-default text-default text-base"
  >
    <SiteNav client:load />
    <section class="flex-grow pt-20" transition:animate={fade({ duration: "0.4s" })}>
      <slot />
    </section>
  </body>
</html>

---
import PostHog from "../components/common/PostHog.astro";
import SiteNav from "../components/SiteNav";
import "../styles/index.css";

const { title } = Astro.props;
---

<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Chat with rAvI" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href={import.meta.env.BASE_URL + "/favicon.svg"} />
    <link rel="sitemap" href={import.meta.env.BASE_URL + "/sitemap-index.xml"} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const modeKey = "themeMode";
        const familySessionKey = "themeFamilySession";
        const stored = localStorage.getItem(modeKey);
        const legacy = localStorage.getItem("theme");
        const mode =
          stored === "light" || stored === "dark" || stored === "system"
            ? stored
            : legacy === "light" || legacy === "dark"
              ? legacy
              : "system";
        const sessionFamily = sessionStorage.getItem(familySessionKey);
        let family =
          sessionFamily === "anthropic" || sessionFamily === "openai" || sessionFamily === "neo"
            ? sessionFamily
            : null;
        if (!family) {
          const families = ["neo", "anthropic", "openai"];
          const index = typeof crypto !== "undefined" && "getRandomValues" in crypto
            ? (() => {
                const values = new Uint32Array(1);
                crypto.getRandomValues(values);
                return values[0] % families.length;
              })()
            : Math.floor(Math.random() * families.length);
          family = families[index] || "neo";
          sessionStorage.setItem(familySessionKey, family);
        }
        const systemTheme = window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
        document.documentElement.dataset.theme =
          mode === "system" ? systemTheme : mode;
        document.documentElement.dataset.themeMode = mode;
        document.documentElement.dataset.themeFamily = family;
      })();
    </script>
    <style>
      body {
        font-family: var(--font-body);
      }
    </style>
    <PostHog />
  </head>
<body class="h-full bg-background text-default">
    <SiteNav client:load />
    <slot />
  </body>
</html>

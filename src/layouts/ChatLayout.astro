---
import PostHog from "../components/common/PostHog.astro";
import QuickBall from "../components/QuickBall";
import "../styles/index.css";

const { title } = Astro.props;
---

<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Chat with rAvI" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href={import.meta.env.BASE_URL + "/favicon.svg"} />
    <link rel="sitemap" href={import.meta.env.BASE_URL + "/sitemap-index.xml"} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const key = "themeMode";
        const stored = localStorage.getItem(key);
        const legacy = localStorage.getItem("theme");
        const mode =
          stored === "light" || stored === "dark" || stored === "system"
            ? stored
            : legacy === "light" || legacy === "dark"
              ? legacy
              : "system";
        const systemTheme = window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
        document.documentElement.dataset.theme =
          mode === "system" ? systemTheme : mode;
        document.documentElement.dataset.themeMode = mode;
      })();
    </script>
    <PostHog />
  </head>
  <body class="h-full bg-black text-default">
    <slot />
    <QuickBall client:load />
  </body>
</html>

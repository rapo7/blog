---
import type { Blog } from '../../../types/BlogType';
import BlogItem from './BlogItem.astro';

const { blogs } = Astro.props;
---

<section class="bg-background px-4 py-14" >
  <div class="mx-auto max-w-5xl">
    <p class="mb-3 inline-flex rounded-full bg-primary px-4 py-2 text-sm font-black uppercase tracking-wide text-default">Thought log</p>
    <h1 class="max-w-4xl text-5xl font-black leading-tight tracking-tight text-default sm:text-6xl">Notes on software, AI, and making systems easier to reason about.</h1>
    <p class="mb-10 mt-5 max-w-3xl text-lg leading-8 text-offset">
      A collection of practical ideas, experiments, and opinions from the workbench.
    </p>
    <div class="space-y-6">
      {blogs
        .slice()
        .sort((a: Blog, b: Blog) => new Date(b.data.datetime).getTime() - new Date(a.data.datetime).getTime())
        .map((blog: Blog, index: number) => (
          <BlogItem blog={blog} isFirst={index === 0} />
        ))}
    </div>
  </div>
</section>

---
const { blog, isFirst } = Astro.props;

---

<a href={`${import.meta.env.BASE_URL}/blogs/${blog.id}`} class="block">
    <div class="group flex flex-col items-start rounded-[1.75rem] border border-default bg-surface p-5 transition md:flex-row
        hover:-translate-y-1 hover:bg-background hover:shadow-[10px_10px_0_#010920]">
        <div class="flex-1 pr-3">
            <h2 class="pt-1 text-2xl font-black leading-tight transition-colors group-hover:text-secondary">
                {blog.data.title}
            </h2>
            <time datetime={blog.data.datetime.toISOString()} class="mt-3 block text-sm font-bold uppercase tracking-wide text-offset">
              {new Date(blog.data.datetime).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <p class="text-offset mt-4 line-clamp-2">{blog.data.description}</p>
        </div>
        {blog.data.image && (
            <div class="mt-4 block w-full overflow-hidden rounded-[1.2rem] border border-default md:w-1/4 lg:mt-1">
                <img src={blog.data.image} alt={blog.data.title}
                    loading={isFirst ? "eager" : "lazy"} 
                    class="aspect-[4/3] w-full object-cover object-center transition-transform duration-300 md:group-hover:scale-105" />
            </div>
        )}
    </div>
</a>

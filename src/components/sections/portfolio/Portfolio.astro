---
import Project from '../Project.astro';
import { projects } from '../../../config/cv.json';
---

<section class="bg-offset px-4 py-16" id="portfolio">
    <div class="mx-auto max-w-7xl">
        <div class="mb-10 grid gap-6 lg:grid-cols-[0.7fr_0.3fr] lg:items-end">
            <div>
                <p class="mb-3 inline-flex rounded-full bg-secondary px-4 py-2 text-sm font-black uppercase tracking-wide text-white">Selected builds</p>
                <h1 class="text-4xl font-black leading-tight tracking-tight text-default lg:text-5xl">
                    Projects with a practical edge.
                </h1>
            </div>
            <p class="text-lg leading-8 text-offset">
                A compact set of work across web apps, systems, cloud tooling, and experiments.
            </p>
        </div>

        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
            {projects.map(project => (
                <Project
                    title={project.title}
                    type={project.type}
                    link={project.link}
                    description={project.description}
                    techStack={project.techStack}
                />
            ))}
        </div>
    </div>
</section>

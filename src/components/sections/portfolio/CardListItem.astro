---
const { title, sub_title, years, details } = Astro.props as {
  title: string;
  sub_title: string;
  years: string;
  details: string[];
};
---

<li class="rounded-[1.35rem] border border-default bg-background p-5 transition hover:-translate-y-1 hover:shadow-[8px_8px_0_#010920]">
  <div class="flex flex-col sm:flex-row justify-between items-start">
    <div class="mb-4 sm:mb-0">
      <h3 class="text-2xl font-black leading-tight">{title}</h3>
      <p class="pt-2 text-base font-bold text-secondary">{sub_title}</p>
    </div>
    <p class="rounded-full bg-offset px-3 py-1 text-sm font-bold text-default sm:text-right whitespace-nowrap">{years}</p>
  </div>
  <ul class="mt-4 space-y-2 text-offset leading-relaxed">
    {details.map(detail => (
      <li class="flex gap-2"><span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-primary"></span><span>{detail}</span></li>
    ))}
  </ul>
</li>

---
import { Image } from "astro:assets";
import heroImage from "../../assets/ravi.png";
import { basic, socialLinks } from "../../config/cv.json";
import { Icon } from "astro-icon/components";
---

<section class="relative overflow-hidden px-4 py-8 sm:py-10 lg:py-12" id="hero">
    <div class="mx-auto max-w-7xl">
        <div class="grid items-center gap-10 lg:grid-cols-[1.05fr_0.95fr]">
            <div class="max-w-3xl">
                <p class="mb-5 inline-flex rounded-full bg-offset px-4 py-2 text-sm font-bold uppercase tracking-wide text-default">
                    {basic?.job} / Cloud / AI
                </p>
                <h1 class="text-5xl font-black leading-[0.98] tracking-tight text-default sm:text-6xl lg:text-[4.35rem]">
                    Building useful software with clear systems and fast feedback.
                </h1>
                <p class="mt-6 max-w-2xl text-lg leading-8 text-offset sm:text-xl">
                    {basic?.summary}
                </p>

                <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:items-center">
                    <a
                        href={`${import.meta.env.BASE_URL}/blogs`}
                        class="inline-flex w-fit items-center rounded-full bg-primary px-6 py-4 text-base font-black text-default shadow-[var(--shadow-card)] transition-colors hover:bg-tertiary"
                    >
                        Read the thought log
                        <span class="ml-3 text-xl leading-none">→</span>
                    </a>
                    <div class="flex gap-3">
                        {
                            socialLinks.map((link) => (
                                <a
                                    href={link.link}
                                    class="flex h-12 w-12 items-center justify-center rounded-full border border-default bg-background transition-colors hover:bg-offset"
                                    aria-label={link.label}
                                >
                                    <Icon
                                        name={link.iconName}
                                        class="h-6 w-6 text-offset"
                                    />
                                </a>
                            ))
                        }
                    </div>
                </div>
            </div>
            <div class="relative">
                <div class="absolute -right-10 -top-8 hidden h-28 w-28 rounded-full bg-secondary md:block"></div>
                <div class="absolute -bottom-8 -left-8 hidden h-24 w-40 rounded-full bg-tertiary md:block"></div>
                <div class="relative rounded-[2rem] border-2 border-default bg-offset p-4 shadow-[var(--shadow-lift)]">
                    <div class="mb-4 flex gap-2">
                        <span class="h-3 w-3 rounded-full bg-secondary"></span>
                        <span class="h-3 w-3 rounded-full bg-tertiary"></span>
                        <span class="h-3 w-3 rounded-full bg-primary"></span>
                    </div>
                    <Image
                        class="max-h-[560px] w-full rounded-[1.4rem] border border-default bg-background object-cover object-top"
                        src={heroImage}
                        loading="eager"
                        alt="Ravi Teja Rapolu - Software Engineer"
                    />
                    <div class="mt-4 rounded-2xl bg-default p-4 text-background">
                        <p class="text-sm font-bold uppercase tracking-wide text-primary">Current focus</p>
                        <p class="mt-1 text-lg font-black">Backend systems, product UI, cloud workflows, and AI tooling.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

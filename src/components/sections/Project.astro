---
import { Icon } from "astro-icon/components";

const { title, type, link, description, techStack = [], years } = Astro.props as {
    title: string;
    type: string;
    link: string;
    description?: string;
    techStack?: string[];
    years?: string;
};
---

<div class="group h-full rounded-[1.75rem] border border-default bg-background p-5 transition-colors hover:bg-surface hover:shadow-[var(--shadow-card)]">
    <a href={link} target="_blank" rel="noopener noreferrer">
        <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-2xl border border-default bg-offset text-default">
            <Icon name="mdi:arrow-top-right-thin-circle-outline" class="h-5 w-5" />
        </div>
        <div class="flex flex-col sm:flex-row justify-between items-start">
            <div class="mb-4 sm:mb-0">
                <h3 class="text-2xl font-black leading-tight group-hover:text-secondary">{title}</h3>
                <p class="pt-2 text-sm font-black uppercase tracking-wide text-tertiary">{type}</p>
            </div>
            {years && <p class="rounded-full bg-offset px-3 py-1 text-sm font-bold text-offset sm:text-right whitespace-nowrap">{years}</p>}
        </div>
        {description && <p class="mt-4 text-offset leading-relaxed">{description}</p>}
        {techStack.length > 0 && (
            <div class="mt-5 flex flex-wrap gap-2">
            {techStack.map(tech => (
                <span class="rounded-full border border-default bg-offset px-3 py-1 text-xs font-black text-default">{tech}</span>
            ))}
            </div>
        )}
    </a>
</div>

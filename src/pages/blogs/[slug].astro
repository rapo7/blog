---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

import Layout from '../../layouts/Layout.astro';
import BlogFAB from '../../components/sections/blog/BlogFAB';

export const getStaticPaths = async () => {
    const blogs = await getCollection("blogs");
    const paths = blogs.map(blog => {
        return {
            params: {
                slug: blog.slug
            },
            props: {
                blog
            }
        }
    });

    return paths;
}

type Props = {
    blog: CollectionEntry<"blogs">
}

const {blog} = Astro.props;
const {Content} = await blog.render();
---

<Layout title={blog.data.title}>
    <section class="mx-auto mt-10 flex max-w-5xl justify-center px-4 sm:mt-14">
        <div id="markdown" class="prose prose-lg relative mb-10 max-w-none rounded-[2rem] border border-default bg-background p-6 shadow-[10px_10px_0_#010920] sm:p-10 lg:p-12">
            <Content />
        </div>
    </section>
    <BlogFAB client:load />


</Layout>
